{
  "expo": {
    "name": "family",
    "slug": "family",
    "scheme": "familyapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "userInterfaceStyle": "light",
      "usesAppleSignIn": true,
      "bundleIdentifier": "com.lounzip.app",
      "infoPlist": {
        "CFBundleDevelopmentRegion": "ko_KR",
        "CFBundleAllowMixedLocalizations": true
      }
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F9E1C7"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.lounzip.app",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "fonts": [
      "./src/assets/fonts/Pretendard-Regular.otf",
      "./src/assets/fonts/Pretendard-Medium.otf",
      "./src/assets/fonts/Pretendard-Bold.otf"
    ],
    "plugins": [
      "expo-font",
      "expo-notifications",
      "expo-apple-authentication",
      [
        "@react-native-seoul/naver-login",
        {
          "urlScheme": "com.lounzip.app"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "프로필과 스토리에 표시할 사진을 선택할 수 있도록 사진에 접근합니다.",
          "cameraPermission": "프로필 사진을 촬영할 수 있도록 카메라를 사용합니다."
        }
      ],
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "238a7d26-904b-4d6f-ad55-d8452aa4af1d"
      }
    },
    "owner": "kimmintae"
  }
}
